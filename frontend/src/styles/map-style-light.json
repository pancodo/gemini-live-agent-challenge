{
  "version": 8,
  "name": "AI Historian Parchment",
  "sources": {
    "openmaptiles": {
      "type": "vector",
      "url": "https://tiles.stadiamaps.com/data/openmaptiles.json"
    }
  },
  "glyphs": "https://tiles.stadiamaps.com/fonts/{fontstack}/{range}.pbf",
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#EBE4D8"
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "water",
      "paint": {
        "fill-color": "#b8ccd8",
        "fill-opacity": 0.6
      }
    },
    {
      "id": "landcover",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landcover",
      "paint": {
        "fill-color": "#d6ccba",
        "fill-opacity": 0.35
      }
    },
    {
      "id": "landuse",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landuse",
      "paint": {
        "fill-color": "#d6ccba",
        "fill-opacity": 0.25
      }
    },
    {
      "id": "boundary-land",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "boundary",
      "filter": ["==", "admin_level", 2],
      "paint": {
        "line-color": "rgba(139, 94, 26, 0.35)",
        "line-width": 1,
        "line-dasharray": [4, 3]
      }
    },
    {
      "id": "waterway",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "waterway",
      "paint": {
        "line-color": "#b8ccd8",
        "line-width": 1,
        "line-opacity": 0.5
      }
    },
    {
      "id": "place-country",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "filter": ["==", "class", "country"],
      "layout": {
        "text-field": "{name}",
        "text-font": ["Stadia Regular"],
        "text-size": 12,
        "text-letter-spacing": 0.3,
        "text-transform": "uppercase",
        "text-max-width": 8
      },
      "paint": {
        "text-color": "#5C3D0E",
        "text-opacity": 0.6,
        "text-halo-color": "#EBE4D8",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "place-city",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "filter": ["==", "class", "city"],
      "layout": {
        "text-field": "{name}",
        "text-font": ["Stadia Regular"],
        "text-size": 10,
        "text-letter-spacing": 0.1,
        "text-max-width": 6
      },
      "paint": {
        "text-color": "#5C3D0E",
        "text-opacity": 0.45,
        "text-halo-color": "#EBE4D8",
        "text-halo-width": 1
      }
    }
  ]
}
