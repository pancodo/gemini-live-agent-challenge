# ── API ──────────────────────────────────────────────────────────
# Backend historian_api base URL
VITE_API_BASE_URL=http://localhost:8000

# ── Live Relay (Berkay's service) ────────────────────────────────
# WebSocket relay for Gemini Live API
VITE_WS_RELAY_URL=ws://localhost:3001

# ── Access Gate (budget protection) ─────────────────────────────
# Leave empty for dev (no gate). Set same value as backend ACCESS_CODE.
VITE_ACCESS_CODE=
