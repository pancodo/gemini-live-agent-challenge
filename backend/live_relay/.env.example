# ── Google Cloud Project ─────────────────────────────────────────
GCP_PROJECT_ID=reference-tine-482314-c6

# ── Vertex AI Region ────────────────────────────────────────────
VERTEX_AI_LOCATION=us-central1

# ── Credentials (local dev only) ────────────────────────────────
# Path to your service account key JSON
# On Cloud Run this is handled automatically via Workload Identity
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# ── Server ───────────────────────────────────────────────────────
# Cloud Run uses 8080
PORT=8080

# ── AI Studio fallback (optional) ───────────────────────────────
# If set, uses AI Studio endpoint instead of Vertex AI
# GEMINI_API_KEY=
