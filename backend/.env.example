# ── Google Cloud Project ─────────────────────────────────────────
GCP_PROJECT_ID=your-project-id

# ── Cloud Storage ────────────────────────────────────────────────
# Bucket for uploaded documents and generated media (images, videos)
GCS_BUCKET_NAME=historian-docs-your-project-id

# ── Document AI ──────────────────────────────────────────────────
# Full resource name: projects/{project}/locations/us/processors/{processor_id}
DOCUMENT_AI_PROCESSOR_NAME=projects/your-project-id/locations/us/processors/your-processor-id

# ── Gemini / Vertex AI ───────────────────────────────────────────
# Region for Vertex AI (Imagen 3, Veo 2)
VERTEX_AI_LOCATION=us-central1

# ── Server ───────────────────────────────────────────────────────
PORT=8000
