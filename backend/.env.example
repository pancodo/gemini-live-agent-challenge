# ── Google Cloud Project ─────────────────────────────────────────
GCP_PROJECT_ID=your-project-id
GOOGLE_CLOUD_PROJECT=your-project-id

# ── Credentials ──────────────────────────────────────────────────
# Path to your service account key JSON (for local dev only)
# In Cloud Run this is handled automatically via Workload Identity
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your-service-account-key.json

# ── Cloud Storage ────────────────────────────────────────────────
GCS_BUCKET_NAME=your-bucket-name

# ── Document AI ──────────────────────────────────────────────────
# Full resource name: projects/{project}/locations/us/processors/{processor_id}
DOCUMENT_AI_PROCESSOR_NAME=projects/your-project-id/locations/us/processors/your-processor-id

# ── Vertex AI / Gemini ───────────────────────────────────────────
VERTEX_AI_LOCATION=us-central1
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=1

# ── Server ───────────────────────────────────────────────────────
PORT=8000
