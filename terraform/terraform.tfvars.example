# Copy this file to terraform.tfvars and fill in your values.
# terraform.tfvars is gitignored — never commit real values.

project_id     = "your-gcp-project-id"
region         = "us-central1"
gemini_api_key = "your-gemini-api-key"
environment    = "production"

# Set to true after pushing container images to Artifact Registry.
# On first apply, leave false — services use gcr.io/cloudrun/hello.
deploy_real_images = false
